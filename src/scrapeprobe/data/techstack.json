  },
  "GitHub Pages": {
    "cats": ["hosting"],
    "headers": {"x-github-request-id": ".", "server": "^GitHub\\.com"},
    "website": "https://pages.github.com"
  },
  "Bunny CDN": {
    "cats": ["cdn"],
    "headers": {"server": "^BunnyCDN-", "cdn-edgeip": ".", "cdn-requestcountrycode": "."},
    "website": "https://bunny.net"
  },
  "Sucuri CDN": {
    "cats": ["cdn", "antibot"],
    "headers": {"server": "^Sucuri", "x-sucuri-id": ".", "x-sucuri-cache": "."},
    "website": "https://sucuri.net"
  },
  "nginx": {
    "cats": ["server"],
    "headers": {"server": "(?i)^nginx"},
