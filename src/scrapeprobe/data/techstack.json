  },
  "Caddy": {
    "cats": ["server"],
    "headers": {"server": "^Caddy"},
    "website": "https://caddyserver.com"
  },
  "LiteSpeed": {
    "cats": ["server"],
    "headers": {"server": "(?i)LiteSpeed", "x-litespeed-cache": "."},
    "website": "https://litespeedtech.com"
  },
  "Google Analytics 4": {
    "cats": ["analytics"],
    "scripts": "googletagmanager\\.com/gtag/js\\?id=G-",
    "html": "gtag\\(\\s*['\"]config['\"]\\s*,\\s*['\"]G-"
  },
  "Google Tag Manager": {
    "cats": ["analytics"],
    "scripts": "googletagmanager\\.com/gtm\\.js",
