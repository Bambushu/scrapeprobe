  },
  "Apache": {
    "cats": ["server"],
    "headers": {"server": "(?i)^Apache(?:$|[/ ])"},
    "website": "https://httpd.apache.org"
  },
  "IIS": {
    "cats": ["server"],
    "headers": {"server": "^Microsoft-IIS/", "x-aspnet-version": ".", "x-powered-by": "ASP\\.NET"},
