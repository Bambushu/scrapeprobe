{
  "_meta": {
    "schema_version": 1,
    "author": "Maikel Slomp",
    "license": "MIT",
    "note": "Hand-curated tech fingerprints. Inspired by Wappalyzer schema. No Wappalyzer signatures copied. Match types: headers (dict regex), cookies (dict regex), html (regex), scripts (regex on <script src>), meta (dict regex on <meta>), generator (regex on <meta name=generator>)."
  },
  "WordPress": {
    "cats": ["cms"],
    "meta": {"generator": "^WordPress"},
    "scripts": "/wp-(?:content|includes)/",
    "html": "<link[^>]+/wp-content/",
    "website": "https://wordpress.org"
  },
  "Drupal": {
    "cats": ["cms"],
    "headers": {"x-generator": "Drupal", "x-drupal-cache": "."},
    "meta": {"generator": "^Drupal"},
    "scripts": "/(?:sites|core)/(?:default|all)/",
    "website": "https://drupal.org"
  },
  "Joomla": {
    "cats": ["cms"],
    "meta": {"generator": "Joomla"},
    "scripts": "/media/jui/",
    "website": "https://joomla.org"
  },
  "Ghost": {
    "cats": ["cms"],
    "meta": {"generator": "^Ghost"},
    "html": "ghost-(?:url|head|sdk)",
    "website": "https://ghost.org"
  },
  "TYPO3": {
    "cats": ["cms"],
    "meta": {"generator": "TYPO3 CMS"},
    "scripts": "/typo3(?:conf|temp)/",
    "website": "https://typo3.org"
  },
  "Contao": {
    "cats": ["cms"],
    "meta": {"generator": "Contao"},
    "website": "https://contao.org"
  },
  "Wix": {
    "cats": ["cms", "hosting"],
    "meta": {"generator": "Wix.com Website Builder"},
    "html": "wix-(?:image|warmup)|static\\.wixstatic\\.com",
    "website": "https://wix.com"
  },
  "Squarespace": {
    "cats": ["cms", "hosting"],
    "html": "static1\\.squarespace\\.com|<!--\\s*This\\s+is\\s+Squarespace",
    "headers": {"x-contextid": "."},
    "website": "https://squarespace.com"
  },
  "Webflow": {
    "cats": ["cms"],
    "meta": {"generator": "Webflow"},
    "scripts": "webflow\\.com/.+/webflow",
    "website": "https://webflow.com"
  },
  "Shopify": {
    "cats": ["ecommerce"],
    "headers": {"x-shopify-stage": ".", "x-shopid": ".", "x-shopify-shop-id": "."},
    "scripts": "cdn\\.shopify\\.com",
    "html": "Shopify\\.theme",
    "website": "https://shopify.com"
  },
  "WooCommerce": {
    "cats": ["ecommerce"],
    "html": "woocommerce-(?:js|page|cart|product|breadcrumb)|/wp-content/plugins/woocommerce/",
    "scripts": "/woocommerce/assets/",
    "website": "https://woocommerce.com"
  },
  "Magento": {
    "cats": ["ecommerce"],
    "cookies": {"X-Magento-Vary": ".", "frontend": "[a-z0-9]{26,}"},
    "html": "Mage\\.(?:Cookies|Translator)|<script[^>]+/mage/",
    "scripts": "/(?:skin|static)/(?:frontend|version)/",
    "website": "https://magento.com"
  },
  "BigCommerce": {
    "cats": ["ecommerce"],
    "headers": {"x-bc-apache-trace-id": ".", "x-bc-cluster-id": "."},
    "scripts": "cdn\\d*\\.bigcommerce\\.com",
    "website": "https://bigcommerce.com"
  },
  "PrestaShop": {
    "cats": ["ecommerce"],
    "html": "var\\s+prestashop\\s*=",
    "meta": {"generator": "PrestaShop"},
    "website": "https://prestashop.com"
  },
  "Salesforce Commerce Cloud": {
    "cats": ["ecommerce"],
    "html": "demandware\\.static|/on/demandware\\.store/",
    "website": "https://salesforce.com/commerce-cloud"
  },
  "Next.js": {
    "cats": ["js-framework"],
    "headers": {"x-powered-by": "^Next\\.js", "x-nextjs-cache": ".", "x-nextjs-prerender": "."},
    "html": "/_next/static/|__NEXT_DATA__",
    "scripts": "/_next/",
    "website": "https://nextjs.org"
  },
  "Nuxt.js": {
    "cats": ["js-framework"],
    "html": "id=\"__nuxt\"|window\\.__NUXT__",
    "scripts": "/_nuxt/",
    "website": "https://nuxt.com"
  },
  "Angular": {
    "cats": ["js-framework"],
    "html": "ng-version=\"|<app-root|<router-outlet|ng-(?:app|controller|repeat|model)=\"",
    "scripts": "/(?:runtime|polyfills|main)\\.[a-f0-9]{16,}\\.js",
    "website": "https://angular.io"
  },
  "React": {
    "cats": ["js-framework"],
    "html": "data-reactroot|data-reactid|__REACT_DEVTOOLS_GLOBAL_HOOK__",
    "website": "https://react.dev"
  },
  "Vue.js": {
    "cats": ["js-framework"],
    "html": "data-v-[a-f0-9]{8}|id=\"app\"[^>]*>\\s*<router-view|__VUE_HMR_RUNTIME__|window\\.__VUE_DEVTOOLS_GLOBAL_HOOK__",
    "website": "https://vuejs.org"
  },
  "Svelte": {
    "cats": ["js-framework"],
    "html": "class=\"svelte-[a-z0-9]{6}|__svelte\\b",
    "website": "https://svelte.dev"
  },
  "SvelteKit": {
    "cats": ["js-framework"],
    "html": "data-sveltekit-(?:preload|reload)|__sveltekit_",
    "website": "https://kit.svelte.dev"
  },
  "Astro": {
    "cats": ["js-framework"],
    "html": "astro-island|data-astro-cid-",
    "meta": {"generator": "Astro"},
    "website": "https://astro.build"
  },
  "Remix": {
    "cats": ["js-framework"],
    "html": "__remixContext|/build/manifest-[A-Z0-9]+\\.js",
    "scripts": "/build/_shared/",
    "website": "https://remix.run"
  },
  "Gatsby": {
    "cats": ["js-framework"],
    "meta": {"generator": "Gatsby"},
    "html": "id=\"___gatsby\"|webpack-runtime-",
    "website": "https://gatsbyjs.com"
  },
  "jQuery": {
    "cats": ["js-framework"],
    "scripts": "/jquery[.-][0-9]"
  },
  "Cloudflare CDN": {
    "cats": ["cdn", "antibot"],
    "headers": {"server": "^cloudflare$", "cf-ray": ".", "cf-cache-status": ".", "cf-edge-cache": "."},
