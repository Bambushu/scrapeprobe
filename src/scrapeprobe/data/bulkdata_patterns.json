{
  "_meta": {
    "schema_version": 1,
    "note": "Open-data endpoint patterns. Tried in order. Both global registry redirects (data.europa.eu, data.gov.X) and on-site paths (/opendata/, /api/, etc.).",
    "license": "MIT"
  },
  "national_registries": {
    "AT": ["https://www.data.gv.at/katalog/dataset?q={host}", "https://data.gv.at/anwendungen/"],
    "DE": ["https://www.govdata.de/web/guest/suchen?q={host}"],
    "NL": ["https://data.overheid.nl/dataset?q={host}"],
    "BE": ["https://data.gov.be/en/dataset?q={host}"],
    "UK": ["https://www.data.gov.uk/search?q={host}"],
    "FR": ["https://www.data.gouv.fr/fr/datasets/?q={host}"],
    "IT": ["https://www.dati.gov.it/search?q={host}"],
    "ES": ["https://datos.gob.es/en/catalogo?q={host}"],
    "SE": ["https://www.dataportal.se/sv/datasets?q={host}"],
    "NO": ["https://data.norge.no/datasets?q={host}"],
    "DK": ["https://datavejviser.dk/search?q={host}"],
    "FI": ["https://www.avoindata.fi/data/en/dataset?q={host}"],
    "CH": ["https://opendata.swiss/en/dataset?q={host}"],
    "IE": ["https://data.gov.ie/dataset?q={host}"],
    "PT": ["https://dados.gov.pt/en/datasets/?q={host}"],
    "PL": ["https://dane.gov.pl/en/dataset?q={host}"],
    "CZ": ["https://data.gov.cz/datasety/?q={host}"],
    "EU": ["https://data.europa.eu/data/datasets?query={host}"],
    "US": ["https://catalog.data.gov/dataset?q={host}"],
    "CA": ["https://open.canada.ca/data/en/dataset?q={host}"],
    "AU": ["https://data.gov.au/search?q={host}"],
    "NZ": ["https://catalogue.data.govt.nz/dataset?q={host}"]
  },
  "on_site_paths": [
    "/opendata/",
    "/open-data/",
    "/api/",
    "/api/v1/",
    "/api/v2/",
    "/api/v3/",
    "/datasets/",
    "/dataset/",
    "/data/",
    "/data.json",
    "/data.csv",
    "/data.xml",
    "/export/",
    "/exports/",
    "/download/",
    "/downloads/",
    "/csv/",
    "/rss",
    "/rss.xml",
    "/feed",
    "/feed/",
    "/feed.xml",
    "/feeds/",
    "/atom.xml",
    "/.well-known/dataset",
    "/api.json",
    "/openapi.json",
    "/swagger.json",
    "/swagger/index.html",
    "/api/swagger-ui.html",
    "/3/action/package_list",
    "/api/3/action/package_list",
    "/odata/",
    "/oData/",
    "/wp-json/wp/v2/posts",
    "/graphql",
    "/api/graphql"
  ]
}
